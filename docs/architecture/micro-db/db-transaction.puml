@startuml db-transaction
title Cơ sở dữ liệu **transaction_db** (transaction-service)

skinparam shadowing false
skinparam defaultFontName Arial
skinparam linetype ortho
skinparam roundCorner 6
skinparam padding 3

skinparam entity {
    BackgroundColor #FFFFFF
    BorderColor #1565C0
    HeaderBackgroundColor #42A5F5
    FontColor #FFFFFF
    StereotypeFontColor #E3F2FD
    AttributeFontColor #1F2937
    AttributeFontSize 11
    FontSize 13
    BorderThickness 1.5
}
skinparam ArrowColor #374151
skinparam ArrowThickness 1.3
skinparam ArrowFontColor #4B5563
skinparam ArrowFontSize 11

' =============================================================
' Bảng: transactions
' =============================================================
entity "transactions" as transactions {
  <color:#B8861B>**# transaction_id**</color> : UUID <<PK>>
  ==
  * request_id : VARCHAR(255) <<UQ>>
  * from_user_id : UUID
    from_phone : VARCHAR(15)
    from_full_name : VARCHAR(100)
  * to_user_id : UUID
    to_phone : VARCHAR(15)
    to_full_name : VARCHAR(100)
  * amount : NUMERIC(18,2)
  * fee : NUMERIC(18,2)
  * transaction_type : VARCHAR(30)
  * status : VARCHAR(20)
    merchant_id : UUID
    description : TEXT
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
  --
  .. Indexes ..
  pk_transactions (transaction_id)
  uq_transactions_request_id (request_id)
  idx_from_user_id (from_user_id)
  idx_to_user_id (to_user_id)
  idx_created_at (created_at)
  .. Checks ..
  transaction_type IN ('TOPUP','TRANSFER','PAYMENT')
  status IN ('PENDING','SUCCESS','FAILED','CANCELLED')
  amount > 0
  fee >= 0
}

' =============================================================
' Bảng: transaction_status_history
' =============================================================
entity "transaction_status_history" as tsh {
  <color:#B8861B>**# history_id**</color> : UUID <<PK>>
  ==
  * <color:#1976D2>transaction_id</color> : UUID <<FK>>
    from_status : VARCHAR(20)
  * to_status : VARCHAR(20)
    reason : VARCHAR(500)
  * changed_at : TIMESTAMP
  --
  .. Indexes ..
  pk_transaction_status_history (history_id)
  idx_tsh_transaction_id (transaction_id)
  idx_tsh_changed_at (changed_at)
  fk_tsh_transaction → transactions(transaction_id)
  .. Checks ..
  from_status IN ('PENDING','SUCCESS','FAILED','CANCELLED')
  to_status IN ('PENDING','SUCCESS','FAILED','CANCELLED')
}

' =============================================================
' Quan hệ FK (cùng database)
' =============================================================
transactions ||--o{ tsh : "lưu lịch sử trạng thái"

' =============================================================
' Cross-service references (logic, không FK cứng)
'   transactions.from_user_id  → users.user_id (user_db)
'   transactions.to_user_id    → users.user_id (user_db)
'   transactions.merchant_id   → merchants.merchant_id (user_db)
'   transactions.transaction_id ← wallet_ledger.transaction_id (wallet_db)
'   transactions.transaction_id ← notification.transaction_id (notification_db)
' =============================================================

legend bottom right
  | Ký hiệu | Ý nghĩa |
  |---|---|
  | <b>#</b>          | Khóa chính (PK) |
  | <b>*</b>          | NOT NULL |
  | (không *)         | NULL được |
  | <<PK>>            | Primary key |
  | <<FK>>            | Foreign key (cùng DB) |
  | <<UQ>>            | UNIQUE constraint |
  | <color:#1976D2>tên xanh</color> | Cột là FK |
endlegend

@enduml
