@startuml use-case-diagram
title Biểu đồ Use Case tổng quát - Hệ thống School Wallet

skinparam shadowing false
skinparam defaultFontName Arial
skinparam packageStyle rectangle
skinparam actorStyle awesome

skinparam usecase {
    BackgroundColor #FFFFFF
    BorderColor #1E40AF
    BorderThickness 1.4
    FontColor #1F2937
    ArrowColor #6B7280
}
skinparam actor {
    BackgroundColor #FFE0B2
    BorderColor #F57C00
    FontColor #1F2937
}
skinparam ArrowColor #6B7280
skinparam ArrowThickness 1.2
skinparam ArrowFontSize 10
skinparam ArrowFontColor #6B7280

left to right direction

' ================== ACTORS ==================
actor "Người dùng" as User
actor "Chủ dịch vụ" as MerchantOwner
actor "Quản trị viên" as Admin

' Quan hệ kế thừa
' - Chủ dịch vụ là Người dùng được cấp quyền sở hữu dịch vụ
' - Quản trị viên là Người dùng có thêm quyền quản trị
MerchantOwner --|> User
Admin         --|> User

' ================== USE CASE - TRƯỚC ĐĂNG NHẬP ==================
usecase "Đăng ký\ntài khoản" as UC_Register
usecase "Đăng nhập" as UC_Login
usecase "Quên mật khẩu" as UC_ForgotPwd

' ================== USE CASE - CHO MỌI NGƯỜI DÙNG ==================
' (Chủ dịch vụ và Quản trị viên tự kế thừa qua Generalization)
usecase "Đăng xuất" as UC_Logout
usecase "Xem trang chính\n(Dashboard)" as UC_Dashboard
usecase "Quản lý\ntài khoản cá nhân" as UC_Profile
usecase "Đổi mật khẩu" as UC_ChangePwd
usecase "Đổi mã PIN\ngiao dịch" as UC_ChangePin
usecase "Cập nhật KYC" as UC_KYC
usecase "Quản lý\nmã QR cá nhân" as UC_QR

usecase "Nạp tiền\n(qua VNPay)" as UC_TopUp
usecase "Chuyển tiền\nqua số điện thoại" as UC_TransferPhone
usecase "Chuyển tiền\nqua mã QR" as UC_TransferQR
usecase "Thanh toán\ndịch vụ" as UC_Payment

usecase "Xem lịch sử\ngiao dịch" as UC_History
usecase "Tra cứu\ngiao dịch theo mã" as UC_Lookup
usecase "Xem thông báo" as UC_Notification

' ================== USE CASE - CHỈ CHỦ DỊCH VỤ ==================
usecase "Xem danh sách\ndịch vụ sở hữu" as UC_MyMerchants
usecase "Xem doanh thu\ndịch vụ sở hữu" as UC_MerchantRevenue

' ================== USE CASE - CHỈ QUẢN TRỊ VIÊN ==================
usecase "Quản lý\nngười dùng" as UC_AdminUser
usecase "Khóa / mở khóa\ntài khoản" as UC_AdminLock
usecase "Cấp lại\nmã PIN" as UC_AdminResetPin
usecase "Quản lý KYC\n(duyệt / từ chối)" as UC_AdminKYC
usecase "Quản lý\ndịch vụ" as UC_AdminMerchant
usecase "Xem thống kê\ngiao dịch hệ thống" as UC_AdminStats
usecase "Xem doanh thu\nnền tảng" as UC_AdminRevenue

' ================== LIÊN KẾT - TRƯỚC ĐĂNG NHẬP ==================
User -- UC_Register
User -- UC_Login
User -- UC_ForgotPwd

' ================== LIÊN KẾT - NGƯỜI DÙNG (Chủ dịch vụ & Admin tự kế thừa) ==================
User -- UC_Logout
User -- UC_Dashboard

User -- UC_Profile
User -- UC_ChangePwd
User -- UC_ChangePin
User -- UC_KYC
User -- UC_QR

User -- UC_TopUp
User -- UC_TransferPhone
User -- UC_TransferQR
User -- UC_Payment

User -- UC_History
User -- UC_Lookup
User -- UC_Notification

' ================== LIÊN KẾT - CHỦ DỊCH VỤ ==================
MerchantOwner -- UC_MyMerchants
MerchantOwner -- UC_MerchantRevenue

' ================== LIÊN KẾT - QUẢN TRỊ VIÊN ==================
Admin -- UC_AdminUser
Admin -- UC_AdminLock
Admin -- UC_AdminResetPin
Admin -- UC_AdminKYC
Admin -- UC_AdminMerchant
Admin -- UC_AdminStats
Admin -- UC_AdminRevenue

' ================== QUAN HỆ <<include>> ==================
' Mọi chức năng sau đăng nhập đều cần đăng nhập trước
UC_Logout         ..> UC_Login : <<include>>
UC_Dashboard      ..> UC_Login : <<include>>
UC_Profile        ..> UC_Login : <<include>>
UC_ChangePwd      ..> UC_Login : <<include>>
UC_ChangePin      ..> UC_Login : <<include>>
UC_KYC            ..> UC_Login : <<include>>
UC_QR             ..> UC_Login : <<include>>
UC_TopUp          ..> UC_Login : <<include>>
UC_TransferPhone  ..> UC_Login : <<include>>
UC_TransferQR     ..> UC_Login : <<include>>
UC_Payment        ..> UC_Login : <<include>>
UC_History        ..> UC_Login : <<include>>
UC_Lookup         ..> UC_Login : <<include>>
UC_Notification   ..> UC_Login : <<include>>
UC_MyMerchants    ..> UC_Login : <<include>>
UC_MerchantRevenue ..> UC_Login : <<include>>
UC_AdminUser      ..> UC_Login : <<include>>
UC_AdminLock      ..> UC_Login : <<include>>
UC_AdminResetPin  ..> UC_Login : <<include>>
UC_AdminKYC       ..> UC_Login : <<include>>
UC_AdminMerchant  ..> UC_Login : <<include>>
UC_AdminStats     ..> UC_Login : <<include>>
UC_AdminRevenue   ..> UC_Login : <<include>>

' ================== QUAN HỆ <<extend>> ==================
' Các chức năng con của "Quản lý tài khoản cá nhân"
UC_ChangePwd ..> UC_Profile : <<extend>>
UC_ChangePin ..> UC_Profile : <<extend>>
UC_KYC       ..> UC_Profile : <<extend>>
UC_QR        ..> UC_Profile : <<extend>>

' Các chức năng con của "Quản lý người dùng" (Admin)
UC_AdminLock     ..> UC_AdminUser : <<extend>>
UC_AdminResetPin ..> UC_AdminUser : <<extend>>

@enduml
